/// Date table for time intelligence over forecast_version. Consume-only (structure only, no business logic).
table Calendar
	lineageTag: 66428e31-b89a-46e9-bb2f-936cc3dcca5a
	dataCategory: Time

	column Date
		dataType: dateTime
		isKey
		lineageTag: 66428e31-cal0-0001-0000-000000000001
		summarizeBy: none
		sourceColumn: [Date]
		dataCategory: PaddedDateTableDates

	column Year
		dataType: int64
		lineageTag: 66428e31-cal0-0001-0000-000000000002
		summarizeBy: none
		sourceColumn: [Year]

	column MonthNo
		dataType: int64
		lineageTag: 66428e31-cal0-0001-0000-000000000003
		summarizeBy: none
		sourceColumn: [MonthNo]

	column Month
		dataType: string
		lineageTag: 66428e31-cal0-0001-0000-000000000004
		summarizeBy: none
		sourceColumn: [Month]
		sortByColumn: MonthNo

	column YearMonth
		dataType: string
		lineageTag: 66428e31-cal0-0001-0000-000000000005
		summarizeBy: none
		sourceColumn: [YearMonth]

	partition Calendar = calculated
		mode: import
		source = ADDCOLUMNS ( CALENDAR ( DATE ( YEAR ( MIN ( forecast_drift_signals[forecast_version] ) ), 1, 1 ), DATE ( YEAR ( MAX ( forecast_drift_signals[forecast_version] ) ), 12, 31 ) ), "Year", YEAR ( [Date] ), "MonthNo", MONTH ( [Date] ), "Month", FORMAT ( [Date], "MMM" ), "YearMonth", FORMAT ( [Date], "YYYY-MM" ) )

