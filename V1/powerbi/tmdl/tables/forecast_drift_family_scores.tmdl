/// Family detail: 4 rows per signal (performance/shape/stability/volatility). Consume-only.
table forecast_drift_family_scores
	lineageTag: 526f0587-219e-4c39-b440-995a243e864f

	measure 'Avg Performance Score' = CALCULATE ( AVERAGE ( forecast_drift_family_scores[family_score] ), forecast_drift_family_scores[drift_family] = "performance" )
		formatString: 0.0
		lineageTag: 038b4af3-9ff0-4ad3-abda-7329a5f08169

	measure 'Avg Shape Score' = CALCULATE ( AVERAGE ( forecast_drift_family_scores[family_score] ), forecast_drift_family_scores[drift_family] = "shape" )
		formatString: 0.0
		lineageTag: 8927f182-a3c6-4d8d-a2bd-c30eafdfe0d0

	measure 'Avg Stability Score' = CALCULATE ( AVERAGE ( forecast_drift_family_scores[family_score] ), forecast_drift_family_scores[drift_family] = "stability" )
		formatString: 0.0
		lineageTag: cee0c5fd-a2f5-46ff-be89-c0224226e6ef

	measure 'Avg Volatility Score' = CALCULATE ( AVERAGE ( forecast_drift_family_scores[family_score] ), forecast_drift_family_scores[drift_family] = "volatility" )
		formatString: 0.0
		lineageTag: e2810698-89f9-4d62-84c1-6dcae3542381

	measure 'NOT_COMPUTABLE Count' = CALCULATE ( COUNTROWS ( forecast_drift_family_scores ), forecast_drift_family_scores[eligibility_status] = "NOT_COMPUTABLE" )
		formatString: #,0
		lineageTag: 3103da5f-dd25-48d8-be31-7b8229b1c548

	measure 'Computed Family Count' = CALCULATE ( COUNTROWS ( forecast_drift_family_scores ), forecast_drift_family_scores[eligibility_status] = "COMPUTED" )
		formatString: #,0
		lineageTag: 77f9a878-e02a-4021-b77a-a40e344db5d1

