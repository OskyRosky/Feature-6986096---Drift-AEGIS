		source = let Source = Csv.Document(File.Contents(DriftDataFolder & "forecast_drift_family_scores.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]), Prom = Table.PromoteHeaders(Source, [PromoteAllScalars=true]) in Prom

